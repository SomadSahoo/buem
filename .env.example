# BUEM Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values for your environment.
# python-dotenv loads .env automatically when buem starts.
# Variables already set in the OS environment are NEVER overridden.
#
# All path values can be absolute or relative to the project root.
# If a variable is left unset, BUEM falls back to sensible defaults
# relative to the installed package location (src/buem/).
# ──────────────────────────────────────────────────────────────────────────────

# Directory containing weather CSV files.
# Default (unset): <package_dir>/data
# Docker default:  /app/data/weather  (set in docker-compose.yml)
#BUEM_WEATHER_DIR=src/buem/data

# Directory for simulation result output.
# Default (unset): <package_dir>/results
#BUEM_RESULTS_DIR=src/buem/results

# Directory for log files.
# Default (unset): <package_dir>/logs
#BUEM_LOG_DIR=src/buem/logs

# Path to the CBC solver binary used by PuLP / cvxpy.
# Default (unset): resolved from PATH at runtime.
# Conda (Linux):   /opt/conda/envs/buem_env/bin/cbc
# Conda (Windows): %CONDA_PREFIX%\Library\bin\cbc.exe
#BUEM_CBC_EXE=

# ──────────────────────────────────────────────────────────────────────────────
# WEATHER PIPELINE — Server-side COSMO-REA6 processing
# ──────────────────────────────────────────────────────────────────────────────
# These variables configure the weather download/processing pipeline that runs
# on a Linux HPC server.  They are NOT needed for the thermal model itself —
# only for `buem weather` CLI commands and the SLURM shell scripts.

# Root of the buem repository on the HPC server.
# SLURM copies scripts to /var/spool, so script-relative paths don't work.
# Default: $HOME/buem
#COSMO_REPO_DIR=$HOME/buem

# The "src" directory — added to PYTHONPATH by run_pipeline.sh.
# Default: $COSMO_REPO_DIR/src
#COSMO_SRC_DIR=$HOME/buem/src

# Base URL of the DWD OpenData COSMO-REA6 hourly 2D archive.
#COSMO_BASE_URL=https://opendata.dwd.de/climate_environment/REA/COSMO_REA6/hourly/2D

# Base URL of COSMO-REA6 constant fields (grid lat/lon, orography, etc.).
#COSMO_CONST_URL=https://opendata.dwd.de/climate_environment/REA/COSMO_REA6/constant

# Root directory for all weather pipeline working data on the server.
# Sub-directories download/, decompress/, processed/, and output/ are created
# automatically under this path.
#COSMO_WORK_DIR=$HOME/buem_weather

# Year to process (default: 2018).
#COSMO_YEAR=2018

# Months to process, comma-separated (default: 01,02,...,12).
# For a single-month test run, set e.g. COSMO_MONTHS=01
#COSMO_MONTHS=01,02,03,04,05,06,07,08,09,10,11,12

# Number of CPU cores available for parallel decompression.
# On SLURM this is typically set by --cpus-per-task; this acts as a fallback.
#COSMO_NCORES=16

# Threads per pbzip2/lbzip2 decompression job (default: 4).
#COSMO_THREADS_PER_JOB=4

# Preferred parallel decompressor: pbzip2, lbzip2, or bzip2 (fallback).
# Auto-detected if unset.
#COSMO_DECOMPRESSOR=

# Conda environment name for the weather pipeline.
#COSMO_CONDA_ENV=weather_env

# Full path to the conda environment directory.
# Default: $HOME/.conda/envs/$COSMO_CONDA_ENV
# Override if your envs are in a non-standard location.
#COSMO_CONDA_ENV_DIR=

# Lmod toolchain year — used by setup_env.sh to `module load` conda
# on HPC systems (e.g. Snellius).  Ignored if conda is already in PATH.
#COSMO_CONDA_TOOLCHAIN=2025

# Lmod module name for Miniconda — used by setup_env.sh.
#COSMO_CONDA_MODULE=Miniconda3/25.5.1-1

# ──────────────────────────────────────────────────────────────────────────────
# WEATHER PIPELINE — Apptainer / Docker container settings
# ──────────────────────────────────────────────────────────────────────────────
# These variables are used by build_container.sh and run_pipeline_container.sh.

# Path to the Apptainer SIF image on the HPC server.
# Default: $HOME/buem_weather.sif
#COSMO_SIF_PATH=$HOME/buem_weather.sif

# Docker registry for push/pull (e.g. docker.io/myuser, ghcr.io/myorg).
# Used by build_container.sh --push and apptainer pull.
#CONTAINER_REGISTRY=

# Docker image tag (default: latest).
#CONTAINER_TAG=latest

# SLURM partition to submit jobs to.
#COSMO_SLURM_PARTITION=rome

# SLURM notification email (optional).
#COSMO_SLURM_EMAIL=

# Conda environment name used by setup.ps1 / setup.bat as a fallback
# when 'buem' is not yet on PATH (i.e. before conda develop src).
# Default: buem_env
#BUEM_CONDA_ENV=buem_env

# API server bind address (used by `buem api` and Gunicorn).
# Default: 127.0.0.1 (loopback; use 0.0.0.0 in Docker)
#BUEM_API_HOST=127.0.0.1

# API server port.
# Default: 5000
#BUEM_API_PORT=5000
