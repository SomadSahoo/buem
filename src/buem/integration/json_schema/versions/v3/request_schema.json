{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://buem.energy/schemas/v3/request",
  "title": "BUEM GeoJSON Request Schema v3",
  "description": "Request schema for the BUEM building energy model. Attributes are separated into four concerns: building (thematic), envelope (geometry), thermal (performance), solver (execution). All measurable quantities carry an explicit unit field. Dimensionless ratios use unit: '-'. SI units are assumed when unit is omitted.",
  "type": "object",
  "required": ["type", "features"],
  "properties": {
    "type": {
      "const": "FeatureCollection",
      "description": "GeoJSON type identifier"
    },
    "timeStamp": {
      "type": "string",
      "format": "date-time",
      "description": "Request timestamp"
    },
    "features": {
      "type": "array",
      "items": { "$ref": "#/$defs/feature" },
      "minItems": 1,
      "description": "Array of building features to process"
    }
  },

  "$defs": {

    "feature": {
      "type": "object",
      "required": ["type", "id", "geometry", "properties"],
      "properties": {
        "type": { "const": "Feature" },
        "id": {
          "type": "string",
          "description": "Unique building identifier"
        },
        "geometry": { "$ref": "#/$defs/geometry" },
        "properties": { "$ref": "#/$defs/properties" }
      }
    },

    "geometry": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "Point" },
        "coordinates": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 3,
          "description": "Geographic coordinates [longitude, latitude, elevation?] — authoritative location, used for weather station lookup"
        }
      }
    },

    "properties": {
      "type": "object",
      "required": ["start_time", "end_time", "buem"],
      "properties": {
        "start_time": {
          "type": "string",
          "format": "date-time",
          "description": "Simulation start time"
        },
        "end_time": {
          "type": "string",
          "format": "date-time",
          "description": "Simulation end time"
        },
        "resolution": {
          "type": "string",
          "default": "60",
          "description": "Time resolution value"
        },
        "resolution_unit": {
          "type": "string",
          "default": "minutes",
          "description": "Time resolution unit"
        },
        "buem": { "$ref": "#/$defs/buem" }
      }
    },

    "buem": {
      "type": "object",
      "required": ["building", "envelope"],
      "description": "BUEM model input — split into building, envelope, thermal, and solver concerns",
      "properties": {
        "building": { "$ref": "#/$defs/building" },
        "envelope":  { "$ref": "#/$defs/envelope" },
        "thermal":   { "$ref": "#/$defs/thermal" },
        "solver":    { "$ref": "#/$defs/solver" }
      }
    },

    "building": {
      "type": "object",
      "description": "Thematic and classification parameters describing what the building is",
      "properties": {
        "A_ref": {
          "allOf": [{ "$ref": "#/$defs/area_qty" }],
          "description": "Reference floor area — derived from envelope element areas if omitted",
          "default": { "value": 0, "unit": "m2" }
        },
        "h_room": {
          "allOf": [{ "$ref": "#/$defs/length_qty" }],
          "description": "Average room height",
          "default": { "value": 2.5, "unit": "m" }
        },
        "n_storeys": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of storeys"
        },
        "building_type": {
          "type": "string",
          "description": "Building type code (e.g. SFH, MFH, AB, TH)"
        },
        "construction_period": {
          "type": "string",
          "description": "Construction period range (e.g. 1965-1974)"
        },
        "country": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2 country code (e.g. NL, DE)"
        },
        "attic_condition": {
          "type": "string",
          "enum": ["-", "N", "P", "C", "NI", "PI"],
          "description": "Attic conditioning status: - not applicable, N not conditioned, P partially, C conditioned, NI not insulated, PI partially insulated"
        },
        "cellar_condition": {
          "type": "string",
          "enum": ["-", "N", "P", "C", "NI", "PI"],
          "description": "Cellar conditioning status"
        },
        "neighbour_status": {
          "type": "string",
          "enum": ["B_Alone", "B_N1", "B_N2"],
          "description": "Attached neighbours: B_Alone detached, B_N1 one shared wall, B_N2 two shared walls"
        }
      }
    },

    "envelope": {
      "type": "object",
      "required": ["elements"],
      "description": "Geometric description of all building envelope elements. Number of elements per type is unconstrained — a building may have any number of walls, roofs, windows, doors, and ventilation systems. Thermal properties for each element are defined separately in thermal.element_properties, linked by id.",
      "properties": {
        "elements": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/envelope_element" },
          "description": "List of all envelope elements. Each element has a user-defined id that must be unique within the feature."
        }
      }
    },

    "envelope_element": {
      "type": "object",
      "required": ["id", "type"],
      "description": "A single building envelope element. All measurable attributes use { value, unit } form. For opaque and transparent elements area, azimuth, and tilt are required. Ventilation elements have no surface geometry.",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "User-defined unique element identifier — referenced by thermal.element_properties"
        },
        "type": {
          "type": "string",
          "enum": ["wall", "roof", "floor", "window", "door", "ventilation"],
          "description": "Element type"
        },
        "area": {
          "allOf": [{ "$ref": "#/$defs/area_qty" }],
          "description": "Element surface area"
        },
        "azimuth": {
          "allOf": [{ "$ref": "#/$defs/angle_qty" }],
          "description": "Orientation measured clockwise from North (0=N, 90=E, 180=S, 270=W)"
        },
        "tilt": {
          "allOf": [
            { "$ref": "#/$defs/angle_qty" },
            { "properties": { "value": { "minimum": 0, "maximum": 90 } } }
          ],
          "description": "Tilt from horizontal (0=horizontal/roof, 90=vertical/wall)"
        },
        "surface": {
          "type": "string",
          "description": "Id of the parent wall element — required for windows and doors"
        }
      },
      "if": {
        "properties": { "type": { "not": { "const": "ventilation" } } }
      },
      "then": {
        "required": ["area", "azimuth", "tilt"]
      }
    },

    "thermal": {
      "type": "object",
      "description": "Thermal performance parameters aligned with IEE TABULA definitions. All fields are optional — implementation defaults (SI units) apply when omitted.",
      "properties": {
        "n_air_infiltration": {
          "allOf": [{ "$ref": "#/$defs/air_change_qty" }],
          "description": "Air change rate due to infiltration — TABULA: n_air_infiltration",
          "default": { "value": 0.5, "unit": "1/h" }
        },
        "n_air_use": {
          "allOf": [{ "$ref": "#/$defs/air_change_qty" }],
          "description": "Air change rate due to building usage / mechanical ventilation — TABULA: n_air_use",
          "default": { "value": 0.5, "unit": "1/h" }
        },
        "c_m": {
          "allOf": [{ "$ref": "#/$defs/heat_capacity_qty" }],
          "description": "Internal thermal capacity per m² of useful floor area — TABULA: c_m",
          "default": { "value": 165.0, "unit": "kJ/(m2K)" }
        },
        "thermal_class": {
          "type": "string",
          "enum": ["light", "medium", "heavy"],
          "default": "medium",
          "description": "ISO 13790 thermal mass class — determines c_m if c_m is not provided explicitly"
        },
        "comfortT_lb": {
          "allOf": [{ "$ref": "#/$defs/temperature_qty" }],
          "description": "Heating setpoint — indoor comfort lower bound",
          "default": { "value": 21.0, "unit": "degC" }
        },
        "comfortT_ub": {
          "allOf": [{ "$ref": "#/$defs/temperature_qty" }],
          "description": "Cooling setpoint — indoor comfort upper bound",
          "default": { "value": 24.0, "unit": "degC" }
        },
        "design_T_min": {
          "allOf": [{ "$ref": "#/$defs/temperature_qty" }],
          "description": "Outdoor design temperature for peak load sizing — TABULA: Theta_e",
          "default": { "value": -12.0, "unit": "degC" }
        },
        "F_sh_hor": {
          "allOf": [{ "$ref": "#/$defs/dimensionless_qty" }],
          "description": "Horizontal shading factor — TABULA: F_sh_hor",
          "default": { "value": 0.80, "unit": "-" }
        },
        "F_sh_vert": {
          "allOf": [{ "$ref": "#/$defs/dimensionless_qty" }],
          "description": "Vertical shading factor — TABULA: F_sh_vert",
          "default": { "value": 0.75, "unit": "-" }
        },
        "F_f": {
          "allOf": [{ "$ref": "#/$defs/dimensionless_qty" }],
          "description": "Window frame area fraction — TABULA: F_f",
          "default": { "value": 0.20, "unit": "-" }
        },
        "F_w": {
          "allOf": [{ "$ref": "#/$defs/dimensionless_qty" }],
          "description": "Window correction factor — TABULA: F_w",
          "default": { "value": 1.0, "unit": "-" }
        },
        "element_properties": {
          "type": "array",
          "items": { "$ref": "#/$defs/thermal_element" },
          "description": "Per-element thermal properties — each entry references an envelope element by id"
        }
      }
    },

    "thermal_element": {
      "type": "object",
      "required": ["id"],
      "description": "Thermal properties for one envelope element, referenced by id. Only the properties relevant to the element type need to be provided.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Matches an id in envelope.elements"
        },
        "U": {
          "allOf": [{ "$ref": "#/$defs/u_value_qty" }],
          "description": "Thermal transmittance — wall, roof, floor, window, door elements"
        },
        "b_transmission": {
          "allOf": [
            { "$ref": "#/$defs/dimensionless_qty" },
            { "properties": { "value": { "minimum": 0, "maximum": 1 } } }
          ],
          "description": "Transmission correction factor — values < 1 for elements adjacent to unheated spaces. TABULA: b_Transmission_*",
          "default": { "value": 1.0, "unit": "-" }
        },
        "g_gl": {
          "allOf": [
            { "$ref": "#/$defs/dimensionless_qty" },
            { "properties": { "value": { "minimum": 0, "maximum": 1 } } }
          ],
          "description": "Solar heat gain coefficient — window elements only. TABULA: g_gl_n_Window",
          "default": { "value": 0.5, "unit": "-" }
        },
        "air_changes": {
          "allOf": [{ "$ref": "#/$defs/air_change_qty" }],
          "description": "Air changes per hour — ventilation elements only"
        }
      }
    },

    "solver": {
      "type": "object",
      "description": "Execution control flags for the thermal solver",
      "properties": {
        "use_milp": {
          "type": "boolean",
          "default": false,
          "description": "Use Mixed Integer Linear Programming solver (CVXPY + CBC) instead of default scipy sparse / OSQP"
        },
        "parallel_thermal": {
          "type": "boolean",
          "default": true,
          "description": "Run heating and cooling simulations in parallel"
        },
        "use_chunked_processing": {
          "type": "boolean",
          "default": true,
          "description": "Process large feature collections in chunks to manage memory"
        }
      }
    },

    "measurement": {
      "type": "object",
      "required": ["value"],
      "description": "Base type for all measurable quantities. The unit field defaults to the SI unit for the quantity type when omitted.",
      "properties": {
        "value": { "type": "number" },
        "unit":  { "type": "string" }
      }
    },

    "area_qty": {
      "allOf": [{ "$ref": "#/$defs/measurement" }],
      "properties": {
        "value": { "minimum": 0 },
        "unit":  { "enum": ["m2", "ft2"], "default": "m2" }
      }
    },

    "length_qty": {
      "allOf": [{ "$ref": "#/$defs/measurement" }],
      "properties": {
        "value": { "minimum": 0 },
        "unit":  { "enum": ["m", "ft"], "default": "m" }
      }
    },

    "angle_qty": {
      "allOf": [{ "$ref": "#/$defs/measurement" }],
      "properties": {
        "value": { "minimum": 0, "maximum": 360 },
        "unit":  { "enum": ["deg", "rad"], "default": "deg" }
      }
    },

    "u_value_qty": {
      "allOf": [{ "$ref": "#/$defs/measurement" }],
      "properties": {
        "value": { "minimum": 0 },
        "unit":  { "enum": ["W/(m2K)", "BTU/(h.ft2.F)"], "default": "W/(m2K)" }
      }
    },

    "air_change_qty": {
      "allOf": [{ "$ref": "#/$defs/measurement" }],
      "properties": {
        "value": { "minimum": 0 },
        "unit":  { "enum": ["1/h"], "default": "1/h" }
      }
    },

    "heat_capacity_qty": {
      "allOf": [{ "$ref": "#/$defs/measurement" }],
      "properties": {
        "value": { "minimum": 0 },
        "unit":  { "enum": ["kJ/(m2K)", "BTU/(ft2.F)"], "default": "kJ/(m2K)" }
      }
    },

    "temperature_qty": {
      "allOf": [{ "$ref": "#/$defs/measurement" }],
      "properties": {
        "unit": { "enum": ["degC", "degF"], "default": "degC" }
      }
    },

    "dimensionless_qty": {
      "allOf": [{ "$ref": "#/$defs/measurement" }],
      "properties": {
        "unit": { "const": "-" }
      },
      "default": { "unit": "-" }
    }

  }
}
