Bootstrap: docker
From: continuumio/miniconda3:latest

# ──────────────────────────────────────────────────────────────────────────────
# COSMO-REA6 Weather Pipeline — Apptainer Definition (deps-only)
# ──────────────────────────────────────────────────────────────────────────────
# Contains the conda environment and system tools ONLY.
# Source code is bind-mounted at runtime → no rebuild needed for code changes.
#
# Rebuild the image only when weather_env.yml changes (new/removed packages).
#
# ── Option 1 (recommended): Build on Snellius pbuild partition ───────────
#   cd ~/buem
#   bash src/buem/weather/shell_scripts/build_container.sh def
#   # Submits a SLURM job to pbuild; SIF appears at ~/buem/buem_weather.sif.
#
# ── Option 2: Build locally (needs root / sudo + Apptainer) ──────────────
#   cd /path/to/buem
#   sudo apptainer build buem_weather.sif src/buem/weather/weather.def
#   scp buem_weather.sif ssahoo@snellius.surf.nl:~/buem/
#
# ── Option 3: Docker → registry → pull on Snellius login node ────────────
#   LOCAL:     docker build -f src/buem/weather/Dockerfile.weather -t buem-weather .
#              docker tag buem-weather docker.io/<user>/buem-weather:latest
#              docker push docker.io/<user>/buem-weather:latest
#   SNELLIUS:  apptainer pull docker://docker.io/<user>/buem-weather:latest
#
# ── Run on Snellius ──────────────────────────────────────────────────────
#   sbatch src/buem/weather/shell_scripts/run_pipeline_container.sh --months 1
#
# Source code is mounted at /app/src at runtime by run_pipeline_container.sh.
# Output: ~/buem/buem_weather.sif (the repo root).
# ──────────────────────────────────────────────────────────────────────────────

%labels
    Author SomadSahoo
    Description COSMO-REA6 weather pipeline for BUEM (deps-only)
    Version 2.0

%files
    src/buem/weather/weather_env.yml /opt/weather_env.yml

%environment
    export PATH=/opt/conda/envs/weather_env/bin:$PATH
    export CONDA_DEFAULT_ENV=weather_env
    export PYTHONPATH=/app/src
    export HDF5_USE_FILE_LOCKING=FALSE

%post
    # System tools
    apt-get update && apt-get install -y --no-install-recommends lbzip2 curl \
        && rm -rf /var/lib/apt/lists/*

    # Update conda to latest version, then create the weather environment
    /opt/conda/bin/conda update -n base -c defaults conda -y --quiet
    /opt/conda/bin/conda env create -f /opt/weather_env.yml
    /opt/conda/bin/conda clean -afy
    rm /opt/weather_env.yml

%runscript
    exec python -m buem.weather "$@"

%test
    # Verify conda env and key packages are importable
    /opt/conda/envs/weather_env/bin/python -c "import xarray, cfgrib, netCDF4; print('OK: core packages importable')"
